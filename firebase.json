{
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "functions/**", ".nojekyll", "README.md"],
    "headers": [{
      "source": "**",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    }]
  }
}
